rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin identity check. The authorized admin UID lives in the
    // /admin/config Firestore doc — NOT in this rules file or in app
    // source code. Bootstrap once via Firebase Console (Console writes
    // bypass rules): create /admin/config with { uid: '<your uid>' }.
    function isAdminUser() {
      return request.auth != null
             && request.auth.token.email_verified == true
             && exists(/databases/$(database)/documents/admin/config)
             && request.auth.uid == get(/databases/$(database)/documents/admin/config).data.uid;
    }

    // Pools — created by anyone authenticated; immutable after creation.
    // The password is gated client-side: client only renders the join form
    // if the user types a password matching the stored hash. The doc only
    // contains the hash + salt + name, so reads don't leak the password.
    match /pools/{poolId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['name', 'passwordHash', 'passwordSalt', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.passwordHash is string
                    && request.resource.data.passwordSalt is string;
      allow update, delete: if false;

      // Brackets — anyone authenticated reads. Writes must preserve the
      // ownerTokenHash that was set on create. The client-side ALSO verifies
      // the writer knows the plaintext token (re-hashes against the salt and
      // compares) before mounting the editor; rules enforce that nobody can
      // change the hash to lock out the original owner.
      match /brackets/{bracketId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.keys().hasAll(['name', 'nickname', 'ownerTokenHash', 'ownerTokenSalt', 'picks', 'updatedAt']);
        allow update: if request.auth != null
                      && request.resource.data.ownerTokenHash == resource.data.ownerTokenHash
                      && request.resource.data.ownerTokenSalt == resource.data.ownerTokenSalt
                      && request.resource.data.name == resource.data.name
                      && request.resource.data.nickname == resource.data.nickname;
        allow delete: if false;
      }
    }

    // Canonical tournament results. Public read (the leaderboard needs it).
    // Writes are gated by isAdminUser() — see comment at top of rules.
    match /results/{docId} {
      allow read: if true;
      allow write: if isAdminUser();
    }

    // Admin config (UID lookup). Public read; the UID is a random
    // Firebase token, not PII. Writes locked to current admin so the
    // admin can rotate it later if needed.
    match /admin/{docId} {
      allow read: if true;
      allow write: if isAdminUser();
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin identity check. The authorized admin UID lives in the
    // /admin/config Firestore doc — NOT in this rules file or in app
    // source code. Bootstrap once via Firebase Console (Console writes
    // bypass rules): create /admin/config with { uid: '<your uid>' }.
    function isAdminUser() {
      return request.auth != null
             && request.auth.token.email_verified == true
             && exists(/databases/$(database)/documents/admin/config)
             && request.auth.uid == get(/databases/$(database)/documents/admin/config).data.uid;
    }

    // Bracket submission deadline: 5:00 PM PT on Wednesday 2026-06-10 (the
    // day before the first World Cup 2026 match, which kicks off 12:00 PT on
    // 2026-06-11). 17:00 PDT = 00:00 UTC on the next day, so the cutoff is
    // exactly UTC midnight on 2026-06-11.
    function beforeSubmitDeadline() {
      return request.time < timestamp.date(2026, 6, 11);
    }

    // A non-anonymous signed-in user (i.e. signed in with Google). Anonymous
    // sessions may read (so leaderboards/brackets are viewable without signing
    // in) but can never own or edit a bracket.
    function isRealUser() {
      return request.auth != null
             && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Collection-group read for brackets. Lets a signed-in user query all of
    // their own brackets across pools (the "your brackets" list), and also
    // covers direct bracket reads. Open to any authed user, anonymous included.
    match /{path=**}/brackets/{bracketId} {
      allow read: if request.auth != null;
    }

    // Pools — created by anyone authenticated; immutable after creation.
    // The password is gated client-side: client only renders the join form
    // if the user types a password matching the stored hash. The doc only
    // contains the hash + salt + name, so reads don't leak the password.
    match /pools/{poolId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['name', 'passwordHash', 'passwordSalt', 'createdAt'])
                    && request.resource.data.name is string
                    && request.resource.data.passwordHash is string
                    && request.resource.data.passwordSalt is string;
      allow update, delete: if false;

      // Brackets — a bracket's doc id IS its owner's Google uid, so ownership
      // is provable from auth alone: only the signed-in owner can create or
      // edit their bracket, and only before the submission deadline. One
      // bracket per user per pool falls out for free. Reads are handled by the
      // collection-group rule above (any authed user, anonymous included).
      match /brackets/{bracketId} {
        // Pool-scoped read for the leaderboard (collection query). Cross-pool
        // reads use the collection-group rule above.
        allow read: if request.auth != null;
        allow create: if isRealUser()
                      && bracketId == request.auth.uid
                      && request.resource.data.ownerUid == request.auth.uid
                      && beforeSubmitDeadline()
                      && request.resource.data.keys().hasAll(['ownerUid', 'nickname', 'picks', 'updatedAt']);
        allow update: if isRealUser()
                      && bracketId == request.auth.uid
                      && resource.data.ownerUid == request.auth.uid
                      && request.resource.data.ownerUid == request.auth.uid
                      && beforeSubmitDeadline();
        allow delete: if false;
      }
    }

    // Canonical tournament results. Public read (the leaderboard needs it).
    // Writes are gated by isAdminUser() — see comment at top of rules.
    match /results/{docId} {
      allow read: if true;
      allow write: if isAdminUser();
    }

    // Admin config (UID lookup). Public read; the UID is a random
    // Firebase token, not PII. Writes locked to current admin so the
    // admin can rotate it later if needed.
    match /admin/{docId} {
      allow read: if true;
      allow write: if isAdminUser();
    }
  }
}
